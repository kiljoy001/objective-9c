import "buffer.o9";

main {
    Buffer b = new Buffer("ab");
    byte c = 67;
    b.appendByte(c);
    b.append("d");
    print("buf ", b.text(), "\n");
    print("len ", b.length(), "\n");
    print("at ", b.byteAt(2), " ", b.byteAt(99), "\n");
    b.setByte(1, 90);
    print("set ", b.text(), "\n");
    print("slice ", b.slice(1, 2), "\n");
    print("hex ", b.hex(), "\n");
    b.clear();
    print("clear ", b.length(), " ", b.empty(), "\n");
}
