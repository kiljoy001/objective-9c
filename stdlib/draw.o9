    c {
        char *s;
        Image *img;
        ulong c;

        out = 0;
        s = o9_string_cstr(text);
        if(handle > 0 && display != nil && screen != nil && font != nil && s != nil){
            c = (ulong)color;
            if((c & 0xFF000000UL) == 0)
                c = ((c & 0xFFFFFFUL) << 8) | 0xFFUL;
            img = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, c);
            if(img != nil){
                string(screen, Pt(screen->r.min.x + x, screen->r.min.y + y), img, ZP, font, s);
                freeimage(img);
                out = 1;
            }
        }
        free(s);
    }
    return out;
}

function DrawCanvasTextBoxRaw(int64 handle, string text, int64 x, int64 y, int64 width, int64 height, int64 color) int64 {
    use { draw }

    int64 out;
    c {
        char *s;
        Image *img;
        Rectangle clip, oldclip;
        Point p;
        ulong c;
        int tw;

        out = 0;
        s = o9_string_cstr(text);
        if(handle > 0 && display != nil && screen != nil && font != nil && s != nil && width > 0 && height > 0){
            c = (ulong)color;
            if((c & 0xFF000000UL) == 0)
                c = ((c & 0xFFFFFFUL) << 8) | 0xFFUL;
            img = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, c);
            if(img != nil){
                clip = Rect(screen->r.min.x + x, screen->r.min.y + y,
                    screen->r.min.x + x + width, screen->r.min.y + y + height);
                oldclip = screen->clipr;
                if(rectclip(&clip, screen->r)){
                    replclipr(screen, 0, clip);
                    tw = stringwidth(font, s);
                    p = Pt(screen->r.min.x + x + (width - tw) / 2,
                        screen->r.min.y + y + (height - font->height) / 2);
                    if(p.x < screen->r.min.x + x)
                        p.x = screen->r.min.x + x;
                    if(p.y < screen->r.min.y + y)
                        p.y = screen->r.min.y + y;
                    string(screen, p, img, ZP, font, s);
                    replclipr(screen, 0, oldclip);
                    out = 1;
                }
                freeimage(img);
            }
        }
        free(s);
    }
    return out;
}

function DrawFrameFlush2Raw(int64 handle, bool clearFirst, bool flushNow, int64 clearColor, int64 count,
                            int64 k0, int64 x0, int64 y0, int64 w0, int64 h0, int64 n0, int64 c0, string s0,
                            int64 k1, int64 x1, int64 y1, int64 w1, int64 h1, int64 n1, int64 c1, string s1) int64 {
    use { draw }

    int64 out;
    c {
        int kind[2];
        vlong xs[2], ys[2], ws[2], hs[2], ns[2], colors[2];
        O9String *texts[2];
        char *text;
        Image *img;
        Rectangle r, clip, oldclip;
        Point p;
        ulong col;
        int i, lim, tw, thick;

        out = 0;
        if(handle > 0 && display != nil && screen != nil){
            kind[0] = k0; xs[0] = x0; ys[0] = y0; ws[0] = w0; hs[0] = h0; ns[0] = n0; colors[0] = c0; texts[0] = s0;
            kind[1] = k1; xs[1] = x1; ys[1] = y1; ws[1] = w1; hs[1] = h1; ns[1] = n1; colors[1] = c1; texts[1] = s1;

            if(clearFirst){
                col = (ulong)clearColor;
                if((col & 0xFF000000UL) == 0)
                    col = ((col & 0xFFFFFFUL) << 8) | 0xFFUL;
                img = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, col);
                if(img != nil){
                    draw(screen, screen->r, img, nil, ZP);
                    freeimage(img);
                }
            }

            lim = count;
            if(lim < 0)
                lim = 0;
            if(lim > 2)
                lim = 2;
            for(i = 0; i < lim; i++){
                if(kind[i] <= 0 || ws[i] <= 0 || hs[i] <= 0)
                    continue;
                col = (ulong)colors[i];
                if((col & 0xFF000000UL) == 0)
                    col = ((col & 0xFFFFFFUL) << 8) | 0xFFUL;
                img = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, col);
                if(img == nil)
                    continue;
                r = Rect(screen->r.min.x + xs[i], screen->r.min.y + ys[i],
                    screen->r.min.x + xs[i] + ws[i], screen->r.min.y + ys[i] + hs[i]);
                if(kind[i] == 1){
                    draw(screen, r, img, nil, ZP);
                } else if(kind[i] == 2){
                    thick = ns[i];
                    if(thick <= 0)
                        thick = 1;
                    border(screen, r, thick, img, ZP);
                } else if(kind[i] == 3 && font != nil){
                    text = o9_string_cstr(texts[i]);
                    if(text != nil){
                        string(screen, Pt(screen->r.min.x + xs[i], screen->r.min.y + ys[i]), img, ZP, font, text);
                        free(text);
                    }
                } else if(kind[i] == 4 && font != nil){
                    text = o9_string_cstr(texts[i]);
                    if(text != nil){
                        clip = r;
                        oldclip = screen->clipr;
                        if(rectclip(&clip, screen->r)){
                            replclipr(screen, 0, clip);
                            tw = stringwidth(font, text);
                            p = Pt(r.min.x + (Dx(r) - tw) / 2, r.min.y + (Dy(r) - font->height) / 2);
                            if(p.x < r.min.x)
                                p.x = r.min.x;
                            if(p.y < r.min.y)
                                p.y = r.min.y;
                            string(screen, p, img, ZP, font, text);
                            replclipr(screen, 0, oldclip);
                        }
                        free(text);
                    }
                } else if(kind[i] == 5 && font != nil){
                    text = o9_string_cstr(texts[i]);
                    if(text != nil){
                        clip = r;
                        oldclip = screen->clipr;
                        if(rectclip(&clip, screen->r)){
                            replclipr(screen, 0, clip);
                            p = Pt(r.min.x, r.min.y + (Dy(r) - font->height) / 2);
                            if(p.y < r.min.y)
                                p.y = r.min.y;
                            string(screen, p, img, ZP, font, text);
                            replclipr(screen, 0, oldclip);
                        }
                        free(text);
                    }
                }
                freeimage(img);
            }
            if(flushNow)
                flushimage(display, 1);
            out = 1;
        }
    }
    return out;
}

