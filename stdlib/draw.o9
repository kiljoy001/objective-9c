function DrawSnapshotRaw(string path, int64 width, int64 height, int64 background, int64 accent) int64 {
    use { memdraw }

    int64 out;
    c {
        char *p;
        Memimage *img, *bar, *block;
        Rectangle r;
        ulong bg, ac, shade;
        int fd, barh, blockw, blockh, x0, y0;

        out = 0;
        p = o9_string_cstr(path);
        if(p != nil && width > 0 && height > 0 && width <= 4096 && height <= 4096){
            bg = (ulong)background;
            ac = (ulong)accent;
            if((bg & 0xFF000000UL) == 0)
                bg = ((bg & 0xFFFFFFUL) << 8) | 0xFFUL;
            if((ac & 0xFF000000UL) == 0)
                ac = ((ac & 0xFFFFFFUL) << 8) | 0xFFUL;
            shade = (((bg >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x30303000UL;

            memimageinit();
            r = Rect(0, 0, width, height);
            img = allocmemimage(r, RGB24);
            if(img != nil){
                memfillcolor(img, bg);

                barh = height / 5;
                if(barh < 4)
                    barh = 4;
                if(barh > height)
                    barh = height;
                bar = allocmemimage(Rect(0, 0, width, barh), RGB24);
                if(bar != nil){
                    memfillcolor(bar, ac);
                    memimagedraw(img, Rect(0, 0, width, barh), bar, ZP, memopaque, ZP, S);
                    freememimage(bar);
                }

                blockw = width / 3;
                blockh = height / 3;
                if(blockw < 4)
                    blockw = 4;
                if(blockh < 4)
                    blockh = 4;
                if(blockw > width)
                    blockw = width;
                if(blockh > height)
                    blockh = height;
                x0 = (width - blockw) / 2;
                y0 = (height - blockh) / 2;
                block = allocmemimage(Rect(0, 0, blockw, blockh), RGB24);
                if(block != nil){
                    memfillcolor(block, shade);
                    memimagedraw(img, Rect(x0, y0, x0 + blockw, y0 + blockh), block, ZP, memopaque, ZP, S);
                    freememimage(block);
                }

                fd = create(p, OWRITE, 0666);
                if(fd >= 0){
                    if(writememimage(fd, img) >= 0)
                        out = 1;
                    close(fd);
                }
                freememimage(img);
            }
        }
        free(p);
    }
    return out;
}

function DrawToPngRaw(string imagePath, string pngPath) int64 {
    int64 out;
    c {
        char *img, *png;
        int fd, pid, ok, got;
        Waitmsg *w;
        Dir *d;

        out = 0;
        img = o9_string_cstr(imagePath);
        png = o9_string_cstr(pngPath);
        if(img != nil && png != nil && img[0] != '\0' && png[0] != '\0'){
            pid = rfork(RFPROC|RFFDG|RFNOTEG);
            if(pid == 0){
                fd = create(png, OWRITE, 0666);
                if(fd < 0)
                    exits("create");
                dup(fd, 1);
                close(fd);
                execl("/bin/topng", "topng", img, nil);
                exits("exec");
            }
            if(pid > 0){
                ok = 0;
                for(;;){
                    w = wait();
                    if(w == nil)
                        break;
                    got = w->pid;
                    if(got == pid && (w->msg == nil || w->msg[0] == '\0'))
                        ok = 1;
                    free(w);
                    if(got == pid)
                        break;
                }
                if(ok){
                    d = dirstat(png);
                    if(d != nil){
                        if(d->length > 0)
                            out = 1;
                        free(d);
                    }
                }
            }
        }
        free(img);
        free(png);
    }
    return out;
}

function DrawRemoveRaw(string path) int64 {
    int64 out;
    c {
        char *p;

        out = 0;
        p = o9_string_cstr(path);
        if(p != nil){
            if(remove(p) == 0)
                out = 1;
            free(p);
        }
    }
    return out;
}

function DrawIntTextRaw(int64 value) string {
    string out;

    c {
        char buf[64];

        snprint(buf, sizeof buf, "%lld", value);
        out = o9_string_from_c(buf);
    }
    return out;
}

function DrawParseIntRaw(string value) int64 {
    int64 out;

    c {
        char *s;

        out = 0;
        s = o9_string_cstr(value);
        if(s != nil){
            out = strtoll(s, nil, 0);
            free(s);
        }
    }
    return out;
}

function DrawTextSliceRaw(string value, int64 start, int64 count) string {
    string out;

    c {
        out = o9_string_slice(value, start, count);
    }
    return out;
}

function DrawTextLineCountRaw(string value, int64 columns, bool wrapText) int64 {
    int64 out;

    c {
        char *s;
        vlong n, i, j, seg, cols;

        s = o9_string_data(value);
        n = o9_string_len(value);
        cols = columns;
        if(cols < 1)
            cols = 1;
        out = 0;
        if(n > 0){
            i = 0;
            while(i <= n){
                j = i;
                while(j < n && s[j] != '\n')
                    j++;
                seg = j - i;
                if(wrapText){
                    if(seg == 0)
                        out++;
                    else
                        out += (seg + cols - 1) / cols;
                }else{
                    out++;
                }
                if(j >= n)
                    break;
                i = j + 1;
                if(i == n)
                    out++;
            }
        }
    }
    return out;
}

function DrawTextMaxLineRaw(string value) int64 {
    int64 out;

    c {
        char *s;
        vlong n, i, cur;

        s = o9_string_data(value);
        n = o9_string_len(value);
        out = 0;
        cur = 0;
        for(i = 0; i < n; i++){
            if(s[i] == '\n'){
                if(cur > out)
                    out = cur;
                cur = 0;
            }else{
                cur++;
            }
        }
        if(cur > out)
            out = cur;
    }
    return out;
}

function DrawTextLineRaw(string value, int64 columns, bool wrapText, int64 line, int64 firstColumn) string {
    string out;

    c {
        O9String *res;
        char *s;
        vlong n, i, j, seg, cols, k, pieces, start, len, col;

        s = o9_string_data(value);
        n = o9_string_len(value);
        cols = columns;
        if(cols < 1)
            cols = 1;
        res = nil;
        if(line >= 0 && n > 0){
            i = 0;
            k = 0;
            while(i <= n){
                j = i;
                while(j < n && s[j] != '\n')
                    j++;
                seg = j - i;
                if(wrapText){
                    pieces = seg == 0 ? 1 : (seg + cols - 1) / cols;
                    if(line >= k && line < k + pieces){
                        start = i + (line - k) * cols;
                        len = cols;
                        if(start + len > j)
                            len = j - start;
                        if(len < 0)
                            len = 0;
                        res = o9_string_new(s + start, len);
                        break;
                    }
                    k += pieces;
                }else{
                    if(line == k){
                        col = firstColumn;
                        if(col < 0)
                            col = 0;
                        if(col > seg)
                            col = seg;
                        res = o9_string_new(s + i + col, seg - col);
                        break;
                    }
                    k++;
                }
                if(j >= n)
                    break;
                i = j + 1;
                if(i == n && line == k){
                    res = o9_string_from_c("");
                    break;
                }
            }
        }
        if(res == nil)
            res = o9_string_from_c("");
        out = res;
    }
    return out;
}

function DrawTextInsertRaw(string value, int64 index, int64 key) string {
    string out;

    c {
        O9String *r;
        char *src, *dst;
        vlong n;

        src = o9_string_data(value);
        n = o9_string_len(value);
        if(index < 0)
            index = 0;
        if(index > n)
            index = n;
        if(key < 32 || key > 126){
            out = o9_string_new(src, n);
        }else{
            r = o9_string_new(nil, n + 1);
            dst = o9_string_data(r);
            if(index > 0)
                memmove(dst, src, index);
            dst[index] = (char)key;
            if(index < n)
                memmove(dst + index + 1, src + index, n - index);
            dst[n + 1] = 0;
            out = r;
        }
    }
    return out;
}

function DrawTextEraseBeforeRaw(string value, int64 index) string {
    string out;

    c {
        O9String *r;
        char *src, *dst;
        vlong n;

        src = o9_string_data(value);
        n = o9_string_len(value);
        if(index < 0)
            index = 0;
        if(index > n)
            index = n;
        if(index <= 0 || n <= 0){
            out = o9_string_new(src, n);
        }else{
            r = o9_string_new(nil, n - 1);
            dst = o9_string_data(r);
            if(index - 1 > 0)
                memmove(dst, src, index - 1);
            if(index < n)
                memmove(dst + index - 1, src + index, n - index);
            dst[n - 1] = 0;
            out = r;
        }
    }
    return out;
}

function DrawTextEraseAtRaw(string value, int64 index) string {
    string out;

    c {
        O9String *r;
        char *src, *dst;
        vlong n;

        src = o9_string_data(value);
        n = o9_string_len(value);
        if(index < 0)
            index = 0;
        if(index >= n || n <= 0){
            out = o9_string_new(src, n);
        }else{
            r = o9_string_new(nil, n - 1);
            dst = o9_string_data(r);
            if(index > 0)
                memmove(dst, src, index);
            if(index + 1 < n)
                memmove(dst + index, src + index + 1, n - index - 1);
            dst[n - 1] = 0;
            out = r;
        }
    }
    return out;
}

function DrawShowRaw(string title, int64 width, int64 height, int64 background, int64 accent, int64 milliseconds) int64 {
    use { draw }

    int64 out;
    c {
        char *t;
        char label[192];
        Image *bg, *bar, *ink, *shade, *panel, *edge;
        Rectangle wr, titlebar, body, card;
        Point p;
        ulong bgc, acc, shadec, panelc;
        int fd, barh, pad, ms;

        out = 0;
        t = o9_string_cstr(title);
        if(t != nil && width > 0 && height > 0 && width <= 4096 && height <= 4096){
            bgc = (ulong)background;
            acc = (ulong)accent;
            if((bgc & 0xFF000000UL) == 0)
                bgc = ((bgc & 0xFFFFFFUL) << 8) | 0xFFUL;
            if((acc & 0xFF000000UL) == 0)
                acc = ((acc & 0xFFFFFFUL) << 8) | 0xFFUL;
            shadec = (((bgc >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x20283000UL;
            panelc = (((bgc >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x10182000UL;

            fd = open("/dev/wctl", OWRITE);
            if(fd >= 0){
                fprint(fd, "resize -dx %lld -dy %lld", width, height);
                close(fd);
            }
            fd = open("/dev/label", OWRITE);
            if(fd >= 0){
                fprint(fd, "%s", t);
                close(fd);
            }

            if(initdraw(nil, nil, t) >= 0){
                bg = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, bgc);
                bar = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, acc);
                ink = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, 0xFFFFFFFFUL);
                shade = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, shadec);
                panel = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, panelc);
                edge = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, 0x405060FFUL);
                if(bg != nil && bar != nil && ink != nil && shade != nil && panel != nil && edge != nil){
                    wr = screen->r;
                    barh = font->height + 14;
                    if(barh < 28)
                        barh = 28;
                    if(barh > Dy(wr))
                        barh = Dy(wr);
                    pad = 10;

                    draw(screen, wr, bg, nil, ZP);
                    titlebar = Rect(wr.min.x, wr.min.y, wr.max.x, wr.min.y + barh);
                    draw(screen, titlebar, bar, nil, ZP);
                    border(screen, insetrect(wr, 1), 1, edge, ZP);

                    snprint(label, sizeof label, "o9 draw: %s", t);
                    p = Pt(wr.min.x + pad, wr.min.y + (barh - font->height) / 2);
                    string(screen, addpt(p, Pt(1, 1)), shade, ZP, font, label);
                    string(screen, p, ink, ZP, font, label);

                    body = Rect(wr.min.x + pad, wr.min.y + barh + pad, wr.max.x - pad, wr.max.y - pad);
                    if(Dx(body) > 8 && Dy(body) > 8){
                        draw(screen, body, shade, nil, ZP);
                        card = insetrect(body, 8);
                        if(Dx(card) > 8 && Dy(card) > font->height + 16){
                            draw(screen, card, panel, nil, ZP);
                            border(screen, card, 1, edge, ZP);
                            p = Pt(card.min.x + 10, card.min.y + 10);
                            string(screen, p, ink, ZP, font, "not in kansas anymore");
                            p = Pt(card.min.x + 10, card.min.y + 10 + font->height + 6);
                            string(screen, p, ink, ZP, font, "o9 stdlib owns this libdraw surface");
                        }
                    }

                    flushimage(display, 1);
                    ms = milliseconds;
                    if(ms <= 0)
                        ms = 3000;
                    sleep(ms);
                    out = 1;
                }
                if(edge != nil)
                    freeimage(edge);
                if(panel != nil)
                    freeimage(panel);
                if(shade != nil)
                    freeimage(shade);
                if(ink != nil)
                    freeimage(ink);
                if(bar != nil)
                    freeimage(bar);
                if(bg != nil)
                    freeimage(bg);
                closedisplay(display);
            }
        }
        free(t);
    }
    return out;
}

function DrawButtonDemoRaw(string title, int64 width, int64 height, int64 background, int64 accent) int64 {
    use { draw event }

    int64 out;
    c {
        char *t;
        char label[192];
        char status[192];
        Image *bg, *bar, *ink, *shade, *panel, *edge, *button, *buttonhot, *buttondown;
        Rectangle wr, titlebar, body, buttonr;
        Event ev;
        Point p;
        ulong bgc, acc, shadec, panelc, buttonc, hotc, downc;
        int fd, barh, pad, bw, bh, et, hot, down, clicks, tw;

        out = 0;
        t = o9_string_cstr(title);
        if(t != nil && width > 0 && height > 0 && width <= 4096 && height <= 4096){
            bgc = (ulong)background;
            acc = (ulong)accent;
            if((bgc & 0xFF000000UL) == 0)
                bgc = ((bgc & 0xFFFFFFUL) << 8) | 0xFFUL;
            if((acc & 0xFF000000UL) == 0)
                acc = ((acc & 0xFFFFFFUL) << 8) | 0xFFUL;
            shadec = (((bgc >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x20283000UL;
            panelc = (((bgc >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x10182000UL;
            buttonc = 0x466080FFUL;
            hotc = 0x5F7FA7FFUL;
            downc = 0xE0C040FFUL;

            fd = open("/dev/wctl", OWRITE);
            if(fd >= 0){
                fprint(fd, "resize -dx %lld -dy %lld", width, height);
                close(fd);
            }
            fd = open("/dev/label", OWRITE);
            if(fd >= 0){
                fprint(fd, "%s", t);
                close(fd);
            }

            if(initdraw(nil, nil, t) >= 0){
                bg = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, bgc);
                bar = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, acc);
                ink = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, 0xFFFFFFFFUL);
                shade = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, shadec);
                panel = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, panelc);
                edge = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, 0xD0D8E0FFUL);
                button = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, buttonc);
                buttonhot = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, hotc);
                buttondown = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, downc);
                if(bg != nil && bar != nil && ink != nil && shade != nil && panel != nil &&
                   edge != nil && button != nil && buttonhot != nil && buttondown != nil){
                    einit(Emouse|Ekeyboard);
                    hot = 0;
                    down = 0;
                    clicks = 0;
                    out = 1;
                    for(;;){
                        wr = screen->r;
                        barh = font->height + 14;
                        if(barh < 28)
                            barh = 28;
                        if(barh > Dy(wr))
                            barh = Dy(wr);
                        pad = 12;

                        bw = Dx(wr) / 3;
                        if(bw < 96)
                            bw = 96;
                        if(bw > Dx(wr) - pad * 2)
                            bw = Dx(wr) - pad * 2;
                        bh = font->height + 18;
                        if(bh < 32)
                            bh = 32;
                        body = Rect(wr.min.x + pad, wr.min.y + barh + pad, wr.max.x - pad, wr.max.y - pad);
                        buttonr = Rect(wr.min.x + (Dx(wr) - bw) / 2,
                            body.min.y + (Dy(body) - bh) / 2,
                            wr.min.x + (Dx(wr) - bw) / 2 + bw,
                            body.min.y + (Dy(body) - bh) / 2 + bh);

                        draw(screen, wr, bg, nil, ZP);
                        titlebar = Rect(wr.min.x, wr.min.y, wr.max.x, wr.min.y + barh);
                        draw(screen, titlebar, bar, nil, ZP);
                        border(screen, insetrect(wr, 1), 1, edge, ZP);

                        snprint(label, sizeof label, "o9 button demo: %s", t);
                        p = Pt(wr.min.x + pad, wr.min.y + (barh - font->height) / 2);
                        string(screen, addpt(p, Pt(1, 1)), shade, ZP, font, label);
                        string(screen, p, ink, ZP, font, label);

                        if(Dx(body) > 8 && Dy(body) > 8){
                            draw(screen, body, shade, nil, ZP);
                            draw(screen, insetrect(body, 8), panel, nil, ZP);
                        }

                        if(clicks == 0)
                            snprint(status, sizeof status, "waiting for click");
                        else if(clicks == 1)
                            snprint(status, sizeof status, "button clicked once");
                        else
                            snprint(status, sizeof status, "button clicked %d times", clicks);
                        tw = stringwidth(font, status);
                        p = Pt(wr.min.x + (Dx(wr) - tw) / 2, buttonr.min.y - font->height - 12);
                        string(screen, p, ink, ZP, font, status);

                        if(down)
                            draw(screen, buttonr, buttondown, nil, ZP);
                        else if(hot)
                            draw(screen, buttonr, buttonhot, nil, ZP);
                        else
                            draw(screen, buttonr, button, nil, ZP);
                        border(screen, buttonr, 1, edge, ZP);
                        snprint(label, sizeof label, "%s", down ? "Pressed" : "Click me");
                        tw = stringwidth(font, label);
                        p = Pt(buttonr.min.x + (Dx(buttonr) - tw) / 2,
                            buttonr.min.y + (Dy(buttonr) - font->height) / 2);
                        string(screen, p, ink, ZP, font, label);
                        flushimage(display, 1);

                        et = event(&ev);
                        if(et == Emouse){
                            hot = ptinrect(ev.mouse.xy, buttonr);
                            if((ev.mouse.buttons & 1) && !down && hot)
                                clicks++;
                            down = ((ev.mouse.buttons & 1) != 0) && hot;
                        } else if(et == Ekeyboard){
                            if(ev.kbdc == 'q' || ev.kbdc == 'Q' || ev.kbdc == 0x1B || ev.kbdc == 0x7F)
                                break;
                        }
                    }
                }
                if(buttondown != nil)
                    freeimage(buttondown);
                if(buttonhot != nil)
                    freeimage(buttonhot);
                if(button != nil)
                    freeimage(button);
                if(edge != nil)
                    freeimage(edge);
                if(panel != nil)
                    freeimage(panel);
                if(shade != nil)
                    freeimage(shade);
                if(ink != nil)
                    freeimage(ink);
                if(bar != nil)
                    freeimage(bar);
                if(bg != nil)
                    freeimage(bg);
                closedisplay(display);
            }
        }
        free(t);
    }
    return out;
}

function DrawProbeSnapshotRaw(string path, int64 width, int64 height, int64 background, int64 accent, int64 count, int64 lastx, int64 lasty, bool pressed) int64 {
    use { memdraw }

    int64 out;
    c {
        char *p;
        Memimage *img, *bar, *button, *buttonedge, *dot, *tick;
        Rectangle r, br, rr;
        ulong bg, ac, body, edge, marker;
        int fd, barh, bx0, by0, bw, bh, i, tx;

        out = 0;
        p = o9_string_cstr(path);
        if(p != nil && width > 0 && height > 0 && width <= 4096 && height <= 4096){
            bg = (ulong)background;
            ac = (ulong)accent;
            if((bg & 0xFF000000UL) == 0)
                bg = ((bg & 0xFFFFFFUL) << 8) | 0xFFUL;
            if((ac & 0xFF000000UL) == 0)
                ac = ((ac & 0xFFFFFFUL) << 8) | 0xFFUL;
            body = pressed ? ac : ((((bg >> 1) & 0x7F7F7F00UL) | 0xFFUL) ^ 0x20202000UL);
            edge = 0xF0F0F0FFUL;
            marker = 0xFFFFFFFFUL;

            memimageinit();
            r = Rect(0, 0, width, height);
            img = allocmemimage(r, RGB24);
            if(img != nil){
                memfillcolor(img, bg);
                barh = height / 6;
                if(barh < 8)
                    barh = 8;
                if(barh > height)
                    barh = height;
                bar = allocmemimage(Rect(0, 0, width, barh), RGB24);
                if(bar != nil){
                    memfillcolor(bar, ac);
                    memimagedraw(img, Rect(0, 0, width, barh), bar, ZP, memopaque, ZP, S);
                    freememimage(bar);
                }

                bw = width / 2;
                bh = height / 4;
                if(bw < 24)
                    bw = 24;
                if(bh < 14)
                    bh = 14;
                if(bw > width - 8)
                    bw = width - 8;
                if(bh > height - barh - 8)
                    bh = height - barh - 8;
                bx0 = (width - bw) / 2;
                by0 = barh + (height - barh - bh) / 2;
                br = Rect(bx0, by0, bx0 + bw, by0 + bh);

                buttonedge = allocmemimage(Rect(0, 0, bw, bh), RGB24);
                button = allocmemimage(Rect(0, 0, bw - 4, bh - 4), RGB24);
                if(buttonedge != nil && button != nil){
                    memfillcolor(buttonedge, edge);
                    memfillcolor(button, body);
                    memimagedraw(img, br, buttonedge, ZP, memopaque, ZP, S);
                    memimagedraw(img, insetrect(br, 2), button, ZP, memopaque, ZP, S);
                }
                if(button != nil)
                    freememimage(button);
                if(buttonedge != nil)
                    freememimage(buttonedge);

                tick = allocmemimage(Rect(0, 0, 4, 8), RGB24);
                if(tick != nil){
                    memfillcolor(tick, edge);
                    for(i = 0; i < count && i < 24; i++){
                        tx = 8 + i * 6;
                        if(tx + 4 <= width)
                            memimagedraw(img, Rect(tx, height - 12, tx + 4, height - 4), tick, ZP, memopaque, ZP, S);
                    }
                    freememimage(tick);
                }

                if(lastx >= 0 && lasty >= 0 && lastx < width && lasty < height){
                    dot = allocmemimage(Rect(0, 0, 5, 5), RGB24);
                    if(dot != nil){
                        memfillcolor(dot, marker);
                        rr = Rect(lastx - 2, lasty - 2, lastx + 3, lasty + 3);
                        memimagedraw(img, rr, dot, ZP, memopaque, ZP, S);
                        freememimage(dot);
                    }
                }

                fd = create(p, OWRITE, 0666);
                if(fd >= 0){
                    if(writememimage(fd, img) >= 0)
                        out = 1;
                    close(fd);
                }
                freememimage(img);
            }
        }
        free(p);
    }
    return out;
}

function DrawCanvasOpenRaw(string title, int64 width, int64 height) int64 {
    use { draw event }

    int64 out;
    c {
        char *t;
        int fd;

        out = 0;
        t = o9_string_cstr(title);
        if(t != nil && width > 0 && height > 0 && width <= 4096 && height <= 4096){
            fd = open("/dev/wctl", OWRITE);
            if(fd >= 0){
                fprint(fd, "resize -dx %lld -dy %lld", width, height);
                close(fd);
            }
            fd = open("/dev/label", OWRITE);
            if(fd >= 0){
                fprint(fd, "%s", t);
                close(fd);
            }
            if(initdraw(nil, nil, t) >= 0){
                einit(Emouse|Ekeyboard);
                if(screen != nil){
                    o9_draw_resized = 0;
                    o9_draw_width = Dx(screen->r);
                    o9_draw_height = Dy(screen->r);
                }
                out = 1;
            }
        }
        free(t);
    }
    return out;
}

function DrawCanvasCloseRaw(int64 handle) int64 {
    use { draw }

    int64 out;
    c {
        out = 0;
        if(handle > 0 && display != nil){
            closedisplay(display);
            display = nil;
            screen = nil;
            out = 1;
        }
    }
    return out;
}

function DrawCanvasClearRaw(int64 handle, int64 color) int64 {
