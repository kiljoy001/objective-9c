    c {
        Image *img;
        Rectangle r;
        ulong c;
        int n;

        out = 0;
        if(handle > 0 && display != nil && screen != nil && width > 0 && height > 0){
            c = (ulong)color;
            if((c & 0xFF000000UL) == 0)
                c = ((c & 0xFFFFFFUL) << 8) | 0xFFUL;
            n = thickness;
            if(n <= 0)
                n = 1;
            r = Rect(screen->r.min.x + x, screen->r.min.y + y,
                screen->r.min.x + x + width, screen->r.min.y + y + height);
            img = allocimage(display, Rect(0, 0, 1, 1), screen->chan, 1, c);
