#!/bin/rc
# sync_and_build.rc -- push updated files to 9front and rebuild

cd /usr/scott/o9_new

# Step 1: Copy the updated o9_plan9.y grammar, o9.h, and runtime
# (these would be pre-scp'd or 9cp'd from Linux)

# Step 2: Rebuild the compiler
echo === YACC ===
rm -f y.tab.* o9c
yacc -d o9_plan9.y >[2] /tmp/yerr.txt
if(! ~ $status 0) { cat /tmp/yerr.txt; exit yacc_failed }
echo YACC_OK

echo === CC ===
6c -o y.tab.6 y.tab.c >[2] /tmp/cerr.txt
if(! ~ $status 0) { cat /tmp/cerr.txt; exit cc_failed }
echo CC_OK

echo === LD ===
6l -o o9c y.tab.6 >[2] /tmp/lerr.txt
if(! ~ $status 0) { cat /tmp/lerr.txt; exit ld_failed }
echo LD_OK
ls -l o9c

echo === BUILD_OK ===
