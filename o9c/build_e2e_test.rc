#!/bin/rc
# build_e2e_test.rc — full pipeline for e2e_test.o9
cd /tmp/o9
6c -FVw o9_runtime.c >[2]/dev/null
6a o9_dispatch.s >[2]/dev/null
ar r libo9.a o9_runtime.6 o9_dispatch.6 >[2]/dev/null
cd o9c
./o9c < test/e2e_test.o9 2> /tmp/out.c
6c -FVw -o /tmp/out.6 /tmp/out.c
6l -o /tmp/o9_test /tmp/out.6 /tmp/o9/libo9.a
rm /srv/Counter >[2]/dev/null
/tmp/o9_test
echo exit_status $status
