// A private method and the constructor must NOT reach the app facade
// (not registered, not in /methods, not ctl-callable), but must still
// work internally (add calls the private bump).
class Counter {
    prop int64 val;
    private method void bump(int64 n) { val = val + n; }
    method void add(int64 n) { bump(n); }
    method int64 get() { return val; }
}
main {
    Counter c = new Counter();
    c.add(5);
    print("val ", c.get(), "\n");
}
