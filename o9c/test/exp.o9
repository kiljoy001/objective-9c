func main() {
    Tabula t = new_tab("orders", "item,qty");
    t.add("a");
    t.set("item", "widget");
    t.set("qty", "5");
    export("", t);
    export(".", t);
    export("..", t);
    export("../escape.tab", t);
    export("bad/name.tab", t);
    export("orders.tab", t);
    t.set("qty", "8");
    export("orders.tab", t);
    print("exported\n");
    serve();
}
