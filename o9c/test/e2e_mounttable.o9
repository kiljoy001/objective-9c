// MountTable - typed namespace syscall parameters stored as Tabula data.
func main() {
    MountTable mt = new MountTable();
    print("schema ", mt.schema(), "\n");
    print("dir ", mt.dir("cache", 493), "\n");
    print("bind ", mt.bind("/tmp", "tmp", 0), "\n");
    print("root ", mt.allowRoot("/tmp/o9_mounttable_root"), "\n");
    print("valid ", mt.validate(), "\n");
    writefile("/tmp/o9_mounttable_probe", "ok");
    print("apply ", mt.apply(), "\n");
    print(readfile("/tmp/o9_mounttable_root/tmp/o9_mounttable_probe"), "\n");

    Tabula binds = mt.query("call", "bind");
    print("q ", binds.first(), " ", binds.get("old"), " ", binds.get("new"), "\n");

    writefile("/tmp/o9_mounttable_spec.tab", mt.read());
    MountTable copy = new MountTable("/tmp/o9_mounttable_spec.tab");
    copy.allowRoot("/tmp/o9_mounttable_root2");
    print("copy ", copy.apply(), "\n");
    print(readfile("/tmp/o9_mounttable_root2/tmp/o9_mounttable_probe"), "\n");

    MountTable bad = new MountTable();
    print("bad ", bad.bind("/tmp", "../escape", 0), "\n");
}
