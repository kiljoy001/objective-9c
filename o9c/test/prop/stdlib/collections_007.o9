main {
    List<int64> xs;
    xs.Add(42);
    xs.Add(1);
    xs.Add(28);
    xs[1] = 94;
    print("list ", xs.Length(), " ", xs[0], " ", xs[1], " ", xs[2], " ", xs[0] + xs[1] + xs[2], "\n");

    Dict<string,int64> nums;
    nums["tabula"] = 42;
    nums["grid"] = 94;
    print("dict ", nums.Has("tabula"), " ", nums.Has("missing"), " ", nums["tabula"], " ", nums["grid"], "\n");

    Dict<int64,string> names;
    names[1] = "tabula";
    names[2] = "grid";
    print("names ", names[1], " ", names[2], "\n");
}
