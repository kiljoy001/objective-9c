main {
    List<int64> xs;
    xs.Add(15);
    xs.Add(10);
    xs.Add(44);
    xs[1] = 90;
    print("list ", xs.Length(), " ", xs[0], " ", xs[1], " ", xs[2], " ", xs[0] + xs[1] + xs[2], "\n");

    Dict<string,int64> nums;
    nums["grid"] = 15;
    nums["beta"] = 90;
    print("dict ", nums.Has("grid"), " ", nums.Has("missing"), " ", nums["grid"], " ", nums["beta"], "\n");

    Dict<int64,string> names;
    names[1] = "grid";
    names[2] = "beta";
    print("names ", names[1], " ", names[2], "\n");
}
