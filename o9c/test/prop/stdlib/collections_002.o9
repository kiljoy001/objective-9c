main {
    List<int64> xs;
    xs.Add(43);
    xs.Add(1);
    xs.Add(41);
    xs[1] = 95;
    print("list ", xs.Length(), " ", xs[0], " ", xs[1], " ", xs[2], " ", xs[0] + xs[1] + xs[2], "\n");

    Dict<string,int64> nums;
    nums["grid"] = 43;
    nums["alpha"] = 95;
    print("dict ", nums.Has("grid"), " ", nums.Has("missing"), " ", nums["grid"], " ", nums["alpha"], "\n");

    Dict<int64,string> names;
    names[1] = "grid";
    names[2] = "alpha";
    print("names ", names[1], " ", names[2], "\n");
}
