#!/bin/rc
# Manual visual demo: compile the DrawButton live libdraw example and open it
# in a rio window when rio's window-control file is available.

tool=./o9c/o9c
src=demo/demo_draw_button.o9
cfile=/tmp/o9_draw_button.$pid.c
ofile=/tmp/o9_draw_button.$pid.6
bin=/tmp/o9_draw_button.$pid
mode=$1

fn depincs {
	awk '/^\/\* o9: include / { print "-I" $4 }' $1
}

fn deparchs {
	awk '/^\/\* o9: archive / { print $4 }' $1
}

if(! test -e $tool){
	echo missing $tool >[1=2]
	exit missing
}
if(! test -e libo9.a){
	echo missing libo9.a >[1=2]
	exit missing
}
if(! $tool < $src > $cfile){
	echo draw-button-demo: transpile failed >[1=2]
	rm -f $cfile $ofile $bin
	exit transpile
}
incs=`{depincs $cfile}
archs=`{deparchs $cfile}
cerr=$ofile^.err
6c -FVw -I. $incs -o $ofile $cfile > $cerr >[2=1]
if(! ~ $status ''){
	cat $cerr >[1=2]
	echo draw-button-demo: compile failed >[1=2]
	rm -f $cfile $ofile $bin $cerr
	exit compile
}
if(grep -s 'warning:' $cerr){
	echo draw-button-demo: 6c warning treated as error >[1=2]
	cat $cerr >[1=2]
	rm -f $cfile $ofile $bin $cerr
	exit warning
}
rm -f $cerr
if(! 6l -o $bin $ofile libo9.a /$objtype/lib/libndb.a $archs){
	echo draw-button-demo: link failed >[1=2]
	rm -f $cfile $ofile $bin
	exit link
}

if(~ $mode compileonly){
	echo draw-button-demo: build OK
	rm -f $cfile $ofile $bin
	exit ''
}

if(test -e /dev/wctl){
	echo 'opening rio window for '$bin
	echo 'click the button; press q, Esc, or Del to close'
	window -dx 460 -dy 300 -noscroll $bin
	exit ''
}
if not{
	echo '/dev/wctl not found; running in current draw context'
	$bin
}

rm -f $cfile $ofile $bin
