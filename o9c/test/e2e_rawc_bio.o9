function countbytes(string path) int64 {
    use { bio }

    int64 n;
    c {
        Biobuf *b;
        char *cpath;

        n = 0;
        cpath = o9_string_cstr(path);
        b = cpath != nil ? Bopen(cpath, OREAD) : nil;
        free(cpath);
        if(b == nil)
            n = -1;
        else {
            while(Bgetc(b) >= 0)
                n++;
            Bterm(b);
        }
    }
    return n;
}

main {
    writefile("/tmp/o9_rawc_bio.txt", "abcde");
    Task<int64> t = spawn countbytes("/tmp/o9_rawc_bio.txt");
    print("bio ", t.await(), "\n");
}
