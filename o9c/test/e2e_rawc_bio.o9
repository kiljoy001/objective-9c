function countbytes(string path) int64 {
    use { bio }

    int64 n;
    c {
        Biobuf *b;
        int ch;

        n = 0;
        b = Bopen(path, OREAD);
        if(b == nil)
            n = -1;
        else {
            while((ch = Bgetc(b)) >= 0)
                n++;
            Bterm(b);
        }
    }
    return n;
}

func main() {
    writefile("/tmp/o9_rawc_bio.txt", "abcde");
    Task<int64> t = spawn countbytes("/tmp/o9_rawc_bio.txt");
    print("bio ", t.await(), "\n");
}
