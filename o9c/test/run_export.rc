#!/bin/rc
# Export regression test — 9front. Builds an o9 program that publishes a
# Tabula into the served-tree exports/ dir, mounts the app's /srv post
# from a SEPARATE namespace, and ASSERTS the exported file appears with
# the expected name and contents. Exits non-zero on any failure (a real
# pass/fail test, not a diagnostic).
#
# Run from the repo root:  rc o9c/test/run_export.rc

tool=./o9c/o9c
# unique app name so cleanup touches ONLY this test's /srv post
app=o9exptest
src=o9c/test/exp.o9
cfile=/tmp/o9exp.$pid.c
ofile=/tmp/o9exp.$pid.6
bin=/tmp/o9exp.$pid
log=/tmp/o9exp.$pid.log
cons_src=/tmp/o9exp_cons.$pid.o9
cons_c=/tmp/o9exp_cons.$pid.c
cons_o=/tmp/o9exp_cons.$pid.6
cons_bin=/tmp/o9exp_cons.$pid
cons_out=/tmp/o9exp_cons.$pid.out
race_out=/tmp/o9exp_race.$pid.out
big=/tmp/o9exp_big.$pid
mtpt=/n/o9exp.$pid
srvglob=/srv/o9.$app.$app.app

fn cleanup {
	unmount $mtpt >[2]/dev/null
	kill o9exp.$pid >[2]/dev/null
	# only our own post — never a blanket /srv/o9.*.app wipe
	rm -f $srvglob $cfile $ofile $bin $log $cons_src $cons_c $cons_o $cons_bin $cons_out $race_out $big
}

fail=0
fn checkfail {
	if(! ~ $1 ''){
		echo 'export: FAIL:' $2 >[1=2]
		fail=1
	}
}

if(! test -e $tool){ echo missing $tool >[1=2]; exit missing }
if(! test -e libo9.a){ echo missing libo9.a >[1=2]; exit missing }

rm -f $srvglob
# build
if(! $tool $src > $cfile){ echo 'export: FAIL: transpile' >[1=2]; exit fail }
if(! 6c -FVw -I. -o $ofile $cfile){ echo 'export: FAIL: 6c' >[1=2]; exit fail }
if(! 6l -o $bin $ofile libo9.a /$objtype/lib/libndb.a){ echo 'export: FAIL: 6l' >[1=2]; exit fail }

# run with our unique app name; watchdog kills it if it hangs
$bin $app > $log >[2=1] &
p=$apid
@{ sleep 15 ; kill $p >[2]/dev/null } &
guard=$apid

# wait for the /srv post to appear (up to ~6s)
i=0
while(! test -e $srvglob && test $i -lt 12){ sleep 1; i=`{echo $i+1|bc} }
if(! test -e $srvglob){
	echo 'export: FAIL: no /srv post at' $srvglob >[1=2]
	cat $log >[1=2]
	kill $p $guard >[2]/dev/null
	cleanup
	exit fail
}

# mount from THIS namespace with create perm and probe
if(! mount -c $srvglob $mtpt){
	echo 'export: FAIL: mount' $srvglob >[1=2]
	kill $p $guard >[2]/dev/null
	cleanup
	exit fail
}

# assertion 1: exports/orders.tab exists
if(! test -e $mtpt/exports/orders.tab){
	echo 'export: FAIL: exports/orders.tab not present' >[1=2]
	ls -l $mtpt/exports >[1=2]
	checkfail x 'missing exports/orders.tab'
}
# assertion 1b: imports/ exists for inert inbound .tab deposits
if(! test -d $mtpt/imports){
	echo 'export: FAIL: imports dir not present' >[1=2]
	ls -l $mtpt >[1=2]
	checkfail x 'missing imports dir'
}
# assertion 2: contents contain the re-exported row data (widget, qty 8)
if(test -e $mtpt/exports/orders.tab){
	got=`{cat $mtpt/exports/orders.tab}
	echo $"got | grep -s widget    ; checkfail $status 'orders missing "widget"'
	echo $"got | grep -s '8'        ; checkfail $status 'orders missing re-exported qty 8'
}

# assertion 3: imports accept committed .tab uploads and preserve bytes
if(test -d $mtpt/imports && test -e $mtpt/exports/orders.tab){
	cat $mtpt/exports/orders.tab > $mtpt/imports/orders.tab
	if(! test -e $mtpt/imports/orders.tab){
		echo 'export: FAIL: imports/orders.tab not created' >[1=2]
		fail=1
	}
	if not{
		igot=`{cat $mtpt/imports/orders.tab}
		echo $"igot | grep -s widget ; checkfail $status 'import missing "widget"'
		echo $"igot | grep -s '8'     ; checkfail $status 'import missing qty 8'
	}
}

# assertion 4: import names must be .tab files, not arbitrary files
@{ echo should-fail > $mtpt/imports/not-tab.txt } >[2]/dev/null
if(~ $status ''){
	echo 'export: FAIL: imports accepted non-.tab name' >[1=2]
	fail=1
}
@{ echo should-fail > $mtpt/imports/bad/name.tab } >[2]/dev/null
if(~ $status ''){
	echo 'export: FAIL: imports accepted nested name' >[1=2]
	fail=1
}
@{ echo should-fail > $mtpt/imports/../escape.tab } >[2]/dev/null
if(~ $status ''){
	echo 'export: FAIL: imports accepted parent escape' >[1=2]
	fail=1
}
if(test -e $mtpt/escape.tab){
	echo 'export: FAIL: import ../escape.tab escaped imports' >[1=2]
	fail=1
}

# assertion 5: import overwrite truncates through per-fid staging
if(test -e $mtpt/imports/orders.tab){
	echo replacement > $mtpt/imports/orders.tab
	igot=`{cat $mtpt/imports/orders.tab}
	if(! ~ $"igot replacement){
		echo 'export: FAIL: import overwrite did not truncate' >[1=2]
		fail=1
	}
}

# assertion 6: reads see only committed import data while another fid is open
if(test -d $mtpt/imports){
	echo old > $mtpt/imports/pending.tab
	@{ echo pending; sleep 2 } > $mtpt/imports/pending.tab &
	sleep 1
	igot=`{cat $mtpt/imports/pending.tab}
	if(! ~ $"igot old){
		echo 'export: FAIL: import exposed uncommitted staged data' >[1=2]
		fail=1
	}
	sleep 2
	igot=`{cat $mtpt/imports/pending.tab}
	if(! ~ $"igot pending){
		echo 'export: FAIL: import did not commit on clunk' >[1=2]
		fail=1
	}
}

# assertion 7: different imports can be written concurrently
if(test -d $mtpt/imports){
	@{ echo alpha > $mtpt/imports/a.tab } &
	@{ echo beta > $mtpt/imports/b.tab } &
	sleep 1
	igot=`{cat $mtpt/imports/a.tab}
	if(! ~ $"igot alpha){
		echo 'export: FAIL: concurrent import a.tab corrupt' >[1=2]
		fail=1
	}
	igot=`{cat $mtpt/imports/b.tab}
	if(! ~ $"igot beta){
		echo 'export: FAIL: concurrent import b.tab corrupt' >[1=2]
		fail=1
	}
}

# assertion 8: same-import races commit one whole staged file, never mixed bytes
if(test -d $mtpt/imports){
	@{ echo A-start; sleep 1; echo A-end } > $mtpt/imports/race.tab &
	@{ echo B-start; sleep 1; echo B-end } > $mtpt/imports/race.tab &
	sleep 3
	cat $mtpt/imports/race.tab > $race_out
	grep -s 'A-start' $race_out; hasa=$status
	grep -s 'B-start' $race_out; hasb=$status
	if(~ $hasa '' && ~ $hasb ''){
		echo 'export: FAIL: same-import race interleaved writers' >[1=2]
		cat $race_out >[1=2]
		fail=1
	}
	if not{
		if(~ $hasa ''){
			grep -s 'A-end' $race_out; checkfail $status 'same-import race lost A end'
		}
		if(~ $hasb ''){
			grep -s 'B-end' $race_out; checkfail $status 'same-import race lost B end'
		}
	}
}

# assertion 9: failed oversized writes do not replace committed import data
if(test -e $mtpt/imports/orders.tab){
	echo safe > $mtpt/imports/orders.tab
	dd -if /dev/zero -of $big -bs 8192 -count 600 >[2]/dev/null
	@{ cat $big > $mtpt/imports/orders.tab } >[2]/dev/null
	igot=`{cat $mtpt/imports/orders.tab}
	if(! ~ $"igot safe){
		echo 'export: FAIL: failed oversized import replaced committed data' >[1=2]
		fail=1
	}
}

# assertion 10: exported files are read-only
@{ echo should-fail > $mtpt/exports/orders.tab } >[2]/dev/null
if(~ $status ''){
	echo 'export: FAIL: exported file accepted write' >[1=2]
	fail=1
}

# assertion 11: unsafe export names did not escape or create nested files
if(test -e $mtpt/escape.tab){
	echo 'export: FAIL: ../escape.tab escaped exports' >[1=2]
	fail=1
}
if(test -e $mtpt/exports/bad){
	echo 'export: FAIL: bad/name.tab created nested export' >[1=2]
	fail=1
}

# assertion 12: a consumer can import the mounted .tab through new Tabula(path)
{
	echo 'main {'
	echo '    Tabula t = new Tabula("'$mtpt'/exports/orders.tab");'
	echo '    print("first ", t.first(), "\n");'
	echo '    print(t.get("item"), " ", t.get("qty"), "\n");'
	echo '}'
} > $cons_src
if(! $tool $cons_src > $cons_c){
	echo 'export: FAIL: consumer transpile' >[1=2]
	fail=1
}
if(~ $fail 0 && ! 6c -FVw -I. -o $cons_o $cons_c){
	echo 'export: FAIL: consumer 6c' >[1=2]
	fail=1
}
if(~ $fail 0 && ! 6l -o $cons_bin $cons_o libo9.a /$objtype/lib/libndb.a){
	echo 'export: FAIL: consumer 6l' >[1=2]
	fail=1
}
if(~ $fail 0){
	$cons_bin > $cons_out >[2=1]
	if(! ~ $status ''){
		echo 'export: FAIL: consumer run' >[1=2]
		cat $cons_out >[1=2]
		fail=1
	}
	if not{
		grep -s 'first 1' $cons_out; checkfail $status 'consumer did not read first row'
		grep -s 'widget 8' $cons_out; checkfail $status 'consumer did not read re-exported row'
	}
}

kill $p $guard >[2]/dev/null
cleanup

if(~ $fail 0)
	echo export: OK
if not
	exit fail
