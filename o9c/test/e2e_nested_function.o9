class Worker {
    function addraw(int64 a, int64 b) int64 {
        int64 out;

        c {
            out = a + b;
        }
        return out;
    }

    method Worker() {
    }

    method int64 add(int64 a, int64 b) {
        Task<int64> t = spawn addraw(a, b);
        return t.await();
    }
}

main {
    Worker w = new Worker();
    print(w.add(20, 22), "\n");
}
