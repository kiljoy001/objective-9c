/* Counter client — call remote counter via /srv/Counter socket */
class Counter {
    int64 val;
    method Counter(int64 n) { val = n; }
    method void inc(int64 n) { val = val + n; }
    method int64 get() { return val; }
}

func main() {
    Counter c = new near Counter("/srv/Counter", 42);
    c.inc(5);
    print(c.get());
    print("\n");
}
