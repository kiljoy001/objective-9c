class Counter {
    int64 val;
    method Counter(int64 n) { val = n; }
    method int64 getValue() { return val; }
    method void inc(int64 n) { val = val + n; }
    method int64 double() => val * 2;
}

main {
    Counter c = new Counter(10);
    c.inc(5);
    c.inc(1);
    int64 v = c.getValue();
    int64 d = c.double();
}
