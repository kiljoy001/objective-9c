#!/bin/rc
# Session lifetime = EXPLICIT conversation (not open-fid lifetime). Proves:
#  1. A session PERSISTS across fid clunks (echo>ctl clunks, then cat data
#     as a separate open still reads the result) — the shell-ergonomics fix.
#  2. Clunking fids does NOT recycle the slot: a 2nd clone WITHOUT close
#     gets a DIFFERENT id (no premature reuse).
#  3. After `echo close > ctl`, the slot IS reused by the next clone
#     (bounded pool, no leak).
# Exits nonzero on fail.
tool=./o9c/o9c
app=o9reuse
src=o9c/test/reap_app.o9
bin=/tmp/o9reuse.$pid
mtpt=/n/o9reuse.$pid
srv=/srv/o9.$app.$app.app
fail=0
fn cleanup { unmount $mtpt >[2]/dev/null; kill o9reuse.$pid >[2]/dev/null; rm -f $srv $bin /tmp/o9reuse.$pid.^* }
if(! $tool $src > /tmp/o9reuse.$pid.c){ echo 'sessreuse: FAIL transpile' >[1=2]; exit fail }
if(! 6c -FVw -I. -o /tmp/o9reuse.$pid.6 /tmp/o9reuse.$pid.c){ echo 'sessreuse: FAIL 6c' >[1=2]; exit fail }
if(! 6l -o $bin /tmp/o9reuse.$pid.6 libo9.a /$objtype/lib/libndb.a){ echo 'sessreuse: FAIL 6l' >[1=2]; exit fail }
rm -f $srv
$bin $app &
p=$apid
@{ sleep 15; kill $p >[2]/dev/null } &
i=0
while(! test -e $srv && test $i -lt 12){ sleep 1; i=`{hoc -e $i+1} }
if(! test -e $srv){ echo 'sessreuse: FAIL no /srv' >[1=2]; cleanup; exit fail }
mount -c $srv $mtpt
# (1) session persists across fid clunks: two separate echo>ctl opens, then cat
sid1=`{cat $mtpt/clone}
echo 'method Counter.a set arg0=7' > $mtpt/$sid1/ctl
echo 'method Counter.a get' > $mtpt/$sid1/ctl
got=`{cat $mtpt/$sid1/data}
if(! ~ $got 7){ echo 'sessreuse: FAIL session did not persist across clunks: data='^$got >[1=2]; fail=1 }
# (2) NOT closed -> next clone gets a DIFFERENT slot (no premature reuse)
sid2=`{cat $mtpt/clone}
if(~ $sid1 $sid2){ echo 'sessreuse: FAIL slot reused without close: sid1='^$sid1^' sid2='^$sid2 >[1=2]; fail=1 }
# (3) close sid1 -> a subsequent clone REUSES it
echo close > $mtpt/$sid1/ctl
sid3=`{cat $mtpt/clone}
if(! ~ $sid1 $sid3){ echo 'sessreuse: FAIL closed slot not reused: sid1='^$sid1^' sid3='^$sid3 >[1=2]; fail=1 }
kill $p >[2]/dev/null
cleanup
if(~ $fail 0) echo sessreuse: OK
if not exit fail
