#!/bin/rc
# Execute-and-assert: transpile, compile, link, RUN, compare stdout.
# 9front only (needs 6c/6l and a running namespace).

tool=./o9c/o9c
fail=0

fn depincs {
	awk '/^\/\* o9: include / { print "-I" $4 }' $1
}

fn deparchs {
	awk '/^\/\* o9: archive / { print $4 }' $1
}

fn runcase {
	name=$1
	src=o9c/test/$name.o9
	expected=o9c/test/$name.expected
	cfile=/tmp/o9_$name.$pid.c
	ofile=/tmp/o9_$name.$pid.6
	bin=/tmp/o9_$name.$pid
	out=/tmp/o9_$name.$pid.out

	# stale service posts from earlier runs make threadpostmountsrv sysfatal
	rm -f /srv/E2Counter /srv/Res /srv/Box__int64 /srv/Box__string

	if(! $tool < $src > $cfile){
		echo $name': transpile failed' >[1=2]
		fail=1
		rm -f $cfile $ofile $bin $out
		broke | rc
		return
	}
	incs=`{depincs $cfile}
	archs=`{deparchs $cfile}
	if(6c -FVw -I. $incs -o $ofile $cfile &&
	   6l -o $bin $ofile libo9.a /$objtype/lib/libndb.a $archs){
		$bin > $out >[2=1]
		if(! ~ $status ''){
			echo $name': run failed:' $status >[1=2]
			fail=1
		}
		if not if(! cmp -s $out $expected){
			echo $name': output mismatch' >[1=2]
			echo '--- expected ---' >[1=2]
			cat $expected >[1=2]
			echo '--- actual ---' >[1=2]
			cat $out >[1=2]
			fail=1
		}
		if not
			echo $name: OK
	}
	if not{
		echo $name': build failed' >[1=2]
		fail=1
	}
	rm -f $cfile $ofile $bin $out
	broke | rc
}

# Like runcase but passes the source PATH (not stdin) so imports resolve
# relative to the file's dir. $1 = subdir/name (under o9c/test).
fn importcase {
	name=$1
	src=o9c/test/$name.o9
	expected=o9c/test/$name.expected
	cfile=/tmp/o9_imp.$pid.c
	ofile=/tmp/o9_imp.$pid.6
	bin=/tmp/o9_imp.$pid
	out=/tmp/o9_imp.$pid.out
	rm -f /srv/o9.*.app
	if(! $tool $src > $cfile){
		echo $name': transpile failed' >[1=2]
		fail=1
		rm -f $cfile $ofile $bin $out /srv/o9.*.app
		broke | rc
		return
	}
	incs=`{depincs $cfile}
	archs=`{deparchs $cfile}
	if(6c -FVw -I. $incs -o $ofile $cfile &&
	   6l -o $bin $ofile libo9.a /$objtype/lib/libndb.a $archs){
		$bin > $out >[2=1]
		if(! cmp -s $out $expected){
			echo $name': output mismatch' >[1=2]
			cat $expected $out >[1=2]
			fail=1
		}
		if not
			echo $name: OK
	}
	if not{
		echo $name': build failed' >[1=2]
		fail=1
	}
	rm -f $cfile $ofile $bin $out /srv/o9.*.app
	broke | rc
}

fn stdlibcase {
	name=$1
	src=stdlib/$name.o9
	expected=stdlib/$name.expected
	cfile=/tmp/o9_stdlib_$name.$pid.c
	ofile=/tmp/o9_stdlib_$name.$pid.6
	bin=/tmp/o9_stdlib_$name.$pid
	out=/tmp/o9_stdlib_$name.$pid.out
	rm -f /srv/o9.*.app
	if(! $tool $src > $cfile){
		echo $name': transpile failed' >[1=2]
		fail=1
		rm -f $cfile $ofile $bin $out /srv/o9.*.app
		broke | rc
		return
	}
	incs=`{depincs $cfile}
	archs=`{deparchs $cfile}
	if(6c -FVw -I. $incs -o $ofile $cfile &&
	   6l -o $bin $ofile libo9.a /$objtype/lib/libndb.a $archs){
		$bin > $out >[2=1]
		if(! cmp -s $out $expected){
			echo $name': output mismatch' >[1=2]
			cat $expected $out >[1=2]
			fail=1
		}
		if not
			echo $name: OK
	}
	if not{
		echo $name': build failed' >[1=2]
		fail=1
	}
	rm -f $cfile $ofile $bin $out /srv/o9.*.app
	broke | rc
}

if(! test -e $tool){
	echo missing $tool >[1=2]
	exit missing
}
if(! test -e libo9.a){
	echo missing libo9.a >[1=2]
	exit missing
}

runcase e2e_run
runcase e2e_text
runcase e2e_delete
runcase e2e_generic
runcase e2e_lookup
runcase e2e_crypto
runcase e2e_send
runcase e2e_secret
runcase e2e_private
runcase e2e_privsame
runcase e2e_clsparam
runcase e2e_twoclass
runcase e2e_state
runcase e2e_error
runcase e2e_try_precedence
runcase e2e_self_send_guard
runcase e2e_tabula
runcase e2e_tabula_methods
runcase e2e_mounttable
runcase e2e_for
runcase e2e_chan
runcase e2e_stream
runcase e2e_alt
runcase e2e_tuple
runcase e2e_typed_chan
runcase e2e_module
runcase e2e_widths
runcase e2e_bool
runcase e2e_byte
runcase e2e_double
runcase e2e_cast
runcase e2e_array_index
runcase e2e_hash_collision
runcase e2e_plan9ctypes
runcase spawn_task
runcase e2e_nested_function
runcase e2e_rawc_function
runcase e2e_rawc_bio
runcase e2e_rawc_draw
runcase e2e_rawc_ctypes
importcase e2e_import
stdlibcase e2e_string
stdlibcase e2e_bytes
stdlibcase e2e_buffer
stdlibcase e2e_collections
stdlibcase e2e_math
stdlibcase e2e_random
stdlibcase e2e_file
stdlibcase e2e_path
stdlibcase e2e_time
stdlibcase e2e_io
stdlibcase e2e_process
stdlibcase e2e_net
stdlibcase e2e_namespace
runcase e2e_hard_recursion
runcase e2e_hard_nesttry
runcase e2e_hard_defer
runcase e2e_hard_field
runcase e2e_hard_deep
runcase e2e_hard_super
# All six adversarial cases resolved (HARD_CASES.md): five fixed, and
# new-inside-a-constructor is now a clean compile error
# (typecheck_bad_ctor_new.o9), not a crash.

if(! ~ $fail 0)
	exit fail
echo e2e_run: OK
