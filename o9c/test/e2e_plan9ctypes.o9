class Plan9Types {
    prop short s;
    prop uint u;
    prop long l;
    prop uchar c;
    prop ushort us;

    method void setup() {
        s = 7;
        u = 11;
        l = 13;
        c = 17;
        us = 19;
    }

    method int64 sum() {
        return s + u + l + c + us;
    }
}

main {
    Plan9Types p = new Plan9Types();
    p.setup();
    print("ctypes ", p.sum(), "\n");
}
