function mix(int a, uint b, short small, long wide, intptr ip, uintptr up, vlong vl, uvlong uvl, uchar uc) uintptr {
    uintptr out;
    c {
        out = (uintptr)(a + b + small + wide + ip + up + vl + uvl + uc);
    }
    return out;
}

main {
    Task<uintptr> t = spawn mix(1, 2, 3, 4, 5, 6, 7, 8, 9);
    uintptr v = t.await();
    print("ctypes ", v, "\n");
}
