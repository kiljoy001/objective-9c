class FlowTest {
    int64 val;
    chan events;
    method void run() {
        val = 0;
        while(val < 10) {
            if(val == 5) {
                events -> val;
            } else {
                val = val + 2;
            }
            if(val != 5) {
                val = val + 1;
            }
        }
    }
}
