// secret fields: the compiler writes the Vault pattern.
// 'secret string apitoken' desugars to apitoken__blob storage plus
// seal_apitoken/open_apitoken — no plain accessor exists, so the
// token is ciphertext in every visible form of the object.
class Account {
    int64 id;
    secret string apitoken;
    method Account(int64 n) { id = n; }
    method int64 get_id() { return id; }
}
func main() {
    string k = passkey("hunter2", "acct.salt.v1");
    Account a = new Account(7);
    a.seal_apitoken(k, "tok-12345");
    print("id ", a.get_id(), "\n");
    print("open ", cmp(a.open_apitoken(k), "tok-12345"), "\n");
    print("wrongkey ", len(a.open_apitoken(keygen())), "\n");
}
