// Server for external-access probing: creates one Counter, then serves
// forever so a separate process can mount /srv/o9.<app> and drive it
// through the flat facade (ctl write -> data read).
class Counter {
    int64 val;
    method Counter(int64 n) { val = n; }
    method void add(int64 n) { val = val + n; }
    method int64 get() { return val; }
}
func main() {
    Counter c = new Counter(40);
    serve();           // block, yielding, so the 9P server keeps answering
}
