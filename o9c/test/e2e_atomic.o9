// atomic field: read-modify-write guarded by a per-field QLock (not a
// spinlock — a spinlock in the cooperative CSP scheduler would let a
// waiter spin without yielding to the holder). The RMW n = n + 1 is
// indivisible under the field's lock, so it's safe when a field is
// touched from more than one proc (the concurrency hook).
class Counter {
    atomic int64 n;
    method void bump() { n = n + 1; }
    method void add(int64 k) { n = n + k; }
    method int64 val() { return n; }
}
func main() {
    Counter c = new Counter();
    c.bump();
    c.bump();
    c.add(10);
    c.bump();
    print("n ", c.val(), "\n");     // 1+1+10+1 = 13
}
