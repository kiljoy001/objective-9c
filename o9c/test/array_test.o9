/* Test: array property member with bracket get/set */
class ArrayHolder {
    int64[] items;
    method ArrayHolder() {
        items[0] = 10;
        items[1] = 20;
        items[2] = 30;
    }
}

func main() {
    ArrayHolder h = new ArrayHolder();
    print("a0: ");
    print(items[0]);
    print(" a1: ");
    print(items[1]);
    print(" a2: ");
    print(items[2]);
    print("\n");
}
